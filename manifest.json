{
  "manifest_version": 3,
  "name": "Naver Store Stock Overlay",
  "description": "Shows detected stock quantity badges on Naver Store PLP product images.",
  "version": "0.2.0",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Naver Store Stock Overlay",
    "default_icon": {
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://smartstore.naver.com/*", "https://brand.naver.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
